# ── Local dev / Docker Compose ────────────────────────────────────────────────
# Copy this file to .env (never commit .env).
# Docker Compose reads .env automatically from the project root.

# PostgreSQL credentials used by the db container and the backend app.
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme_strong_password

# Grafana admin UI password
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_password

# Backend DATABASE_URL (matches the values above)
DATABASE_URL=postgresql://admin:changeme_strong_password@localhost:5432/asset_compliance

# ── AWS / Terraform ───────────────────────────────────────────────────────────
# Supply these as environment variables or in infra/terraform/terraform.tfvars
# (never commit terraform.tfvars).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Terraform variables — alternatively set as TF_VAR_* env vars:
#   export TF_VAR_db_password=<strong-password>
#   export TF_VAR_github_repo=https://github.com/you/your-repo.git
#   export TF_VAR_allowed_ssh_cidr=$(curl -s ifconfig.me)/32

# ── Jenkins deploy ────────────────────────────────────────────────────────────
# Set these as Jenkins credentials / environment variables, not in this file.
EC2_HOST=your-ec2-elastic-ip
SSH_KEY_PATH=/path/to/your/key.pem
